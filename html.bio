<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Abshar Athulam Punathil</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg:          #060010;
      --white:       #ffffff;
      --text:        rgba(255,255,255,0.85);
      --muted:       rgba(255,255,255,0.42);
      --purple:      #7C3AED;
      --purple-soft: rgba(124, 58, 237, 0.18);
      --violet:      #A78BFA;
      --blue:        #2563EB;
      --cyan:        #06B6D4;
      --glass-bg:    rgba(255,255,255,0.04);
      --glass-bd:    rgba(255,255,255,0.08);
      --radius:      18px;
      --font:        'Inter', sans-serif;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--font);
      background: var(--bg);
      color: var(--text);
      overflow-x: hidden;
      min-height: 100vh;
    }

    /* ══ Blobs ══ */
    .blobs {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      overflow: hidden;
    }
    .blob {
      position: absolute;
      border-radius: 50%;
      filter: blur(100px);
    }
    .b1 {
      width: 520px; height: 520px;
      background: rgba(124, 58, 237, 0.22);
      top: -12%; left: -10%;
      animation: f1 15s ease-in-out infinite;
    }
    .b2 {
      width: 420px; height: 420px;
      background: rgba(37, 99, 235, 0.18);
      top: 35%; right: -8%;
      animation: f2 19s ease-in-out infinite;
    }
    .b3 {
      width: 360px; height: 360px;
      background: rgba(6, 182, 212, 0.13);
      bottom: -6%; left: 28%;
      animation: f3 17s ease-in-out infinite;
    }
    @keyframes f1 {
      0%,100% { transform: translate(0,0) scale(1); }
      50%      { transform: translate(50px,70px) scale(1.08); }
    }
    @keyframes f2 {
      0%,100% { transform: translate(0,0) scale(1); }
      50%      { transform: translate(-55px,-45px) scale(0.94); }
    }
    @keyframes f3 {
      0%,100% { transform: translate(0,0) scale(1); }
      50%      { transform: translate(35px,-55px) scale(1.06); }
    }

    /* ══ Nav ══ */
    nav {
      position: fixed;
      inset: 0 0 auto 0;
      z-index: 100;
      height: 62px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 clamp(20px, 6vw, 80px);
      background: rgba(6, 0, 16, 0.55);
      backdrop-filter: blur(28px);
      -webkit-backdrop-filter: blur(28px);
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .nav-logo {
      font-weight: 800;
      font-size: 1.05rem;
      letter-spacing: -0.02em;
      color: var(--white);
      text-decoration: none;
    }
    .nav-logo .dot { color: var(--violet); }
    .nav-links { display: flex; gap: 30px; list-style: none; }
    .nav-links a {
      font-size: 0.8rem;
      font-weight: 500;
      letter-spacing: 0.04em;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--white); }

    /* ══ Hero ══ */
    #hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      padding: 100px clamp(20px, 8vw, 100px) 60px;
      position: relative;
      z-index: 1;
    }
    .hero-inner { max-width: 680px; }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 5px 14px 5px 10px;
      border-radius: 100px;
      border: 1px solid rgba(167,139,250,0.22);
      background: rgba(124,58,237,0.1);
      font-size: 0.74rem;
      font-weight: 500;
      letter-spacing: 0.05em;
      color: var(--violet);
      margin-bottom: 30px;
    }
    .badge-dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--violet);
      animation: pulse 2s ease-in-out infinite;
    }
    @keyframes pulse {
      0%,100% { opacity: 1; transform: scale(1); }
      50%      { opacity: 0.5; transform: scale(0.8); }
    }

    h1.hero-name {
      font-size: clamp(3rem, 8vw, 5.8rem);
      font-weight: 900;
      line-height: 1.0;
      letter-spacing: -0.035em;
      color: var(--white);
      margin-bottom: 18px;
    }

    .typer-line {
      font-size: clamp(1rem, 2vw, 1.15rem);
      font-weight: 400;
      color: rgba(167,139,250,0.75);
      min-height: 1.6em;
      margin-bottom: 28px;
      display: flex;
      align-items: center;
      gap: 3px;
    }
    .cursor {
      display: inline-block;
      width: 2px;
      height: 1em;
      background: var(--violet);
      animation: blink 1s step-end infinite;
    }
    @keyframes blink { 50% { opacity: 0; } }

    .hero-bio {
      font-size: 1.05rem;
      line-height: 1.82;
      color: var(--muted);
      max-width: 520px;
      margin-bottom: 42px;
    }
    .hero-bio strong {
      color: rgba(255,255,255,0.78);
      font-weight: 600;
    }

    .hero-cta {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 13px 30px;
      border-radius: 14px;
      background: rgba(124,58,237,0.82);
      border: 1px solid rgba(167,139,250,0.28);
      backdrop-filter: blur(10px);
      color: var(--white);
      font-size: 0.9rem;
      font-weight: 600;
      text-decoration: none;
      transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    }
    .hero-cta:hover {
      background: rgba(124,58,237,1);
      transform: translateY(-2px);
      box-shadow: 0 14px 40px rgba(124,58,237,0.42);
    }

    /* ══ Section base ══ */
    .section {
      padding: 90px clamp(20px, 8vw, 100px);
      position: relative;
      z-index: 1;
    }
    .section-inner { max-width: 1040px; margin: 0 auto; }

    .sec-label {
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: rgba(167,139,250,0.65);
      margin-bottom: 12px;
    }
    .sec-title {
      font-size: clamp(1.8rem, 3.5vw, 2.6rem);
      font-weight: 800;
      letter-spacing: -0.025em;
      color: var(--white);
      margin-bottom: 36px;
      line-height: 1.1;
    }

    /* ══ Skills ══ */
    .skills-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px,1fr));
      gap: 13px;
    }

    .skill-card {
      background: var(--glass-bg);
      backdrop-filter: blur(22px);
      -webkit-backdrop-filter: blur(22px);
      border: 1px solid var(--glass-bd);
      border-radius: var(--radius);
      padding: 26px 22px;
      transition: transform 0.25s, background 0.25s, border-color 0.25s, box-shadow 0.25s;
    }
    .skill-card:hover {
      transform: translateY(-5px);
      background: rgba(255,255,255,0.07);
      border-color: rgba(167,139,250,0.22);
      box-shadow: 0 18px 52px rgba(124,58,237,0.16);
    }

    .sk-icon { font-size: 1.7rem; margin-bottom: 13px; display: block; }
    .sk-name { font-size: 0.97rem; font-weight: 700; color: var(--white); margin-bottom: 5px; }
    .sk-note { font-size: 0.8rem; color: var(--muted); line-height: 1.6; }

    .pill {
      display: inline-block;
      margin-top: 13px;
      padding: 3px 10px;
      border-radius: 100px;
      font-size: 0.66rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .p-good     { background: rgba(34,197,94,0.1);   color: #86EFAC; border: 1px solid rgba(34,197,94,0.2); }
    .p-ok       { background: rgba(124,58,237,0.14); color: #C4B5FD; border: 1px solid rgba(124,58,237,0.25); }
    .p-learning { background: rgba(6,182,212,0.1);   color: #67E8F9; border: 1px solid rgba(6,182,212,0.2); }

    /* ══ Contact ══ */
    #contact { border-top: 1px solid rgba(255,255,255,0.04); }

    .contact-row {
      display: flex;
      gap: 13px;
      flex-wrap: wrap;
    }
    .contact-card {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 18px 26px;
      background: var(--glass-bg);
      backdrop-filter: blur(22px);
      -webkit-backdrop-filter: blur(22px);
      border: 1px solid var(--glass-bd);
      border-radius: 16px;
      text-decoration: none;
      color: var(--text);
      min-width: 200px;
      transition: all 0.25s;
    }
    .contact-card:hover {
      background: rgba(255,255,255,0.08);
      border-color: rgba(167,139,250,0.28);
      transform: translateY(-3px);
      box-shadow: 0 14px 36px rgba(124,58,237,0.2);
    }
    .contact-card svg { width: 22px; height: 22px; fill: var(--violet); flex-shrink: 0; }
    .cp { font-size: 0.62rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); display: block; margin-bottom: 2px; }
    .ch { font-size: 0.92rem; font-weight: 600; color: var(--white); }

    /* ══ Reveal ══ */
    .reveal { opacity: 0; transform: translateY(22px); transition: opacity 0.6s ease, transform 0.6s ease; }
    .reveal.vis { opacity: 1; transform: none; }
    .d1 { transition-delay: 0.08s; }
    .d2 { transition-delay: 0.16s; }
    .d3 { transition-delay: 0.24s; }
    .d4 { transition-delay: 0.32s; }
    .d5 { transition-delay: 0.40s; }

    /* ══ Footer ══ */
    footer {
      padding: 24px clamp(20px, 6vw, 80px);
      border-top: 1px solid rgba(255,255,255,0.04);
      text-align: center;
      font-size: 0.77rem;
      color: var(--muted);
      position: relative;
      z-index: 1;
    }

    /* ══ Mobile ══ */
    @media (max-width: 600px) {
      .nav-links { display: none; }
      .contact-row { flex-direction: column; }
      .contact-card { min-width: unset; }
    }
  </style>
</head>
<body>

  <!-- Background blobs -->
  <div class="blobs">
    <div class="blob b1"></div>
    <div class="blob b2"></div>
    <div class="blob b3"></div>
  </div>

  <!-- Nav -->
  <nav>
    <a href="#hero" class="nav-logo">Abshar<span class="dot">.</span></a>
    <ul class="nav-links">
      <li><a href="#skills">Skills</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
  </nav>

  <!-- Hero -->
  <section id="hero">
    <div class="hero-inner">

      <div class="badge">
        <span class="badge-dot"></span>
        self-taught · still learning
      </div>

      <h1 class="hero-name">Abshar<br>Athulam Punathil</h1>

      <div class="typer-line">
        <span id="typerEl"></span><span class="cursor"></span>
      </div>

      <p class="hero-bio">
        No degree, no bootcamp — just <strong>curiosity and a lot of late nights.</strong>
        I taught myself Python, HTML, C++, and a bit of Java. I build stuff for the web,
        run tools I find interesting online, and keep learning as I go.
        Still early in the journey, but getting there.
      </p>

      <a href="#contact" class="hero-cta">Say hi →</a>

    </div>
  </section>

  <!-- Skills -->
  <section class="section" id="skills">
    <div class="section-inner">
      <p class="sec-label reveal">what i know so far</p>
      <h2 class="sec-title reveal d1">Skills & Languages</h2>

      <div class="skills-grid">

        <div class="skill-card reveal d1">
          <span class="sk-icon">🐍</span>
          <div class="sk-name">Python</div>
          <div class="sk-note">Most comfortable here. Scripts, automation, tinkering with tools I find on GitHub.</div>
          <span class="pill p-good">Comfortable</span>
        </div>

        <div class="skill-card reveal d2">
          <span class="sk-icon">🌐</span>
          <div class="sk-name">HTML & Web Dev</div>
          <div class="sk-note">Know my way around the front end. Building pages and experimenting with layouts.</div>
          <span class="pill p-good">Comfortable</span>
        </div>

        <div class="skill-card reveal d3">
          <span class="sk-icon">⚙️</span>
          <div class="sk-name">C++</div>
          <div class="sk-note">Got the fundamentals down. Can read and write basic programs without too much Googling.</div>
          <span class="pill p-ok">Intermediate</span>
        </div>

        <div class="skill-card reveal d4">
          <span class="sk-icon">☕</span>
          <div class="sk-name">Java</div>
          <div class="sk-note">Just getting into it. Basics are there, slowly building confidence with it.</div>
          <span class="pill p-learning">Learning</span>
        </div>

        <div class="skill-card reveal d5">
          <span class="sk-icon">🔧</span>
          <div class="sk-name">Security Tooling</div>
          <div class="sk-note">Running and exploring open-source tools, learning how things work underneath.</div>
          <span class="pill p-learning">Exploring</span>
        </div>

      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="section" id="contact">
    <div class="section-inner">
      <p class="sec-label reveal">hit me up</p>
      <h2 class="sec-title reveal d1">Contact</h2>

      <div class="contact-row">

        <a href="https://www.instagram.com/_aabshrr" target="_blank" rel="noopener" class="contact-card reveal d2">
          <svg viewBox="0 0 448 512"><path d="M224,202.66A53.34,53.34,0,1,0,277.34,256,53.38,53.38,0,0,0,224,202.66Zm124.71-41a54.65,54.65,0,0,0-30.82-30.81C284.23,122.16,224,120,224,120s-60.23,2.16-93.89,10.84a54.65,54.65,0,0,0-30.82,30.81C84.16,155.77,82,216,82,216s2.16,60.23,10.84,93.89a54.65,54.65,0,0,0,30.82,30.82C163.77,389.84,224,392,224,392s60.23-2.16,93.89-10.84a54.65,54.65,0,0,0,30.82-30.82C363.84,276.23,366,216,366,216S363.84,155.77,348.71,161.66ZM224,338a82,82,0,1,1,82-82A82.1,82.1,0,0,1,224,338Zm85.33-148.67a19.2,19.2,0,1,1,19.2-19.2A19.2,19.2,0,0,1,309.33,189.33Z"/></svg>
          <div>
            <span class="cp">Instagram</span>
            <span class="ch">@_aabshrr</span>
          </div>
        </a>

        <a href="https://wa.me/79645909" target="_blank" rel="noopener" class="contact-card reveal d3">
          <svg viewBox="0 0 448 512"><path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"/></svg>
          <div>
            <span class="cp">WhatsApp</span>
            <span class="ch">79645909</span>
          </div>
        </a>

      </div>
    </div>
  </section>

  <footer>© 2025 Abshar Athulam Punathil</footer>

  <script>
    /* Typewriter */
    const lines = [
      'self-taught developer',
      'into python & web dev',
      'picking up c++ & java',
      'building things that work',
      'still learning every day',
    ];
    const el = document.getElementById('typerEl');
    let li = 0, ci = 0, del = false;
    function tick() {
      const cur = lines[li];
      el.textContent = del ? cur.slice(0, --ci) : cur.slice(0, ++ci);
      if (!del && ci === cur.length) { del = true; setTimeout(tick, 2000); return; }
      if (del && ci === 0)           { del = false; li = (li + 1) % lines.length; setTimeout(tick, 350); return; }
      setTimeout(tick, del ? 38 : 68);
    }
    tick();

    /* Scroll reveal */
    const ro = new IntersectionObserver(entries =>
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('vis'); ro.unobserve(e.target); } }),
      { threshold: 0.1 }
    );
    document.querySelectorAll('.reveal').forEach(el => ro.observe(el));
  </script>

</body>
</html>
